{
  "name": "myaichat",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "generate:key": "node ./scripts/gen-key.js",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "typeorm": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js",
    "migration:run": "npm run typeorm migration:run -- -d src/config/db/db.datasource.ts",
    "migration:revert": "npm run typeorm migration:revert -- -d src/config/db/db.datasource.ts",
    "migration:show": "npm run typeorm migration:show -- -d src/config/db/db.datasource.ts",
    "migration:create": "npm run typeorm migration:create --",
    "migration:generate": "npm run typeorm migration:generate -- -d src/config/db/db.datasource.ts",
    "migration:user:generate": "node scripts/migration-run.js user generate",
    "migration:user:create": "node scripts/migration-run.js user create",
    "migration:auth:generate": "node scripts/migration-run.js auth generate",
    "migration:auth:create": "node scripts/migration-run.js auth create",
    "migration:chat:generate": "node scripts/migration-run.js chat generate",
    "migration:chat:create": "node scripts/migration-run.js chat create",
    "migration:prompts:generate": "node scripts/migration-run.js prompts generate",
    "migration:prompts:create": "node scripts/migration-run.js prompts create",
    "migration:models:generate": "node scripts/migration-run.js models generate",
    "migration:models:create": "node scripts/migration-run.js models create",
    "migration:run:prod": "node typeorm-cli.js migration:run",
    "migration:revert:prod": "node typeorm-cli.js migration:revert",
    "migration:show:prod": "node typeorm-cli.js migration:show"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.943.0",
    "@google/genai": "1.41.0",
    "@keyv/redis": "^5.1.5",
    "@nestjs/cache-manager": "^3.0.1",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^11.0.1",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/swagger": "^11.2.6",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/typeorm": "^11.0.0",
    "cache-manager": "^7.2.7",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.3",
    "cookie-parser": "^1.4.7",
    "date-fns": "^4.1.0",
    "multer": "^2.0.2",
    "openai": "6.22.0",
    "pg": "^8.16.3",
    "pkce-challenge": "^5.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.27",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/multer": "^2.0.0",
    "@types/node": "^22.10.7",
    "@types/supertest": "^6.0.2",

    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "jest": "^30.0.0",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "overrides": {
    "minimatch": "^10.2.1",
    "ajv": "^8.18.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "transformIgnorePatterns": [
      "/node_modules/(?!(p-retry|is-network-error)/)"
    ],
    "collectCoverageFrom": [
      "**/*.(t|j)s",
      "!**/migrations/**",
      "!**/*.module.ts",
      "!**/*.datasource.ts",
      "!**/*.typeorm.ts",
      "!**/index.ts",
      "!**/main.ts"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^@cfg/(.*)$": "<rootDir>/config/$1",
      "^@cmn/(.*)$": "<rootDir>/common/$1",
      "^@mod/(.*)$": "<rootDir>/modules/$1",
      "^@auth/(.*)$": "<rootDir>/modules/auth/$1",
      "^@usr/(.*)$": "<rootDir>/modules/user/$1",
      "^@chat/(.*)$": "<rootDir>/modules/chat/$1",
      "^@prompts/(.*)$": "<rootDir>/modules/prompts/$1",
      "^@models/(.*)$": "<rootDir>/modules/models/$1",
      "^@mdl/(.*)$": "<rootDir>/modules/models/$1",
      "^@s3/(.*)$": "<rootDir>/modules/s3/$1"
    }
  }
}
